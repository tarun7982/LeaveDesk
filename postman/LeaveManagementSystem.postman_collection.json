{
  "info": {
    "name": "Leave Management System API",
    "description": "Employee Leave Management System - REST API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "leaveId", "value": "1" },
    { "key": "employeeId", "value": "2" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Employee)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employee@company.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login (Manager)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@company.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees (Manager only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees?search=&department=&role="
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        },
        {
          "name": "Create Employee (Manager only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Hire\",\n  \"email\": \"newhire@company.com\",\n  \"password\": \"Password@123\",\n  \"department\": \"Engineering\",\n  \"role\": \"EMPLOYEE\",\n  \"manager_id\": 1\n}"
            },
            "url": "{{baseUrl}}/employees"
          }
        }
      ]
    },
    {
      "name": "Leaves (Employee)",
      "item": [
        {
          "name": "Apply for Leave",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leave_type\": \"CASUAL\",\n  \"start_date\": \"2026-08-01\",\n  \"end_date\": \"2026-08-02\",\n  \"reason\": \"Personal work\"\n}"
            },
            "url": "{{baseUrl}}/leaves"
          }
        },
        {
          "name": "List My Leaves (search/filter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves?status=&leave_type=&search="
          }
        },
        {
          "name": "Get Leave by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Edit Pending Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Updated reason for leave\"\n}"
            },
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Cancel Pending Leave",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/{{leaveId}}"
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/leaves/dashboard-stats"
          }
        }
      ]
    },
    {
      "name": "Manager Operations",
      "item": [
        {
          "name": "View Pending Leaves",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/pending-leaves?search=&leave_type="
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"comments\": \"Approved\"\n}" },
            "url": "{{baseUrl}}/leaves/{{leaveId}}/approve"
          }
        },
        {
          "name": "Reject Leave (comments required)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"comments\": \"Insufficient leave balance\"\n}" },
            "url": "{{baseUrl}}/leaves/{{leaveId}}/reject"
          }
        },
        {
          "name": "Search Team Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/employees?search=&department="
          }
        }
      ]
    }
  ]
}
